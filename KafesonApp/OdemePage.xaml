<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.OdemePage"
             xmlns:models="clr-namespace:Kafeson.Shared.Models;assembly=Kafeson.Shared"
             Title=""
             BackgroundColor="#F4F6FB">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Padding="0">

        <Grid Grid.Row="0" BackgroundColor="White" ColumnDefinitions="Auto, *, Auto" Padding="20,52,20,20">
            <Grid.Shadow>
                <Shadow Brush="#CBD5E1" Offset="0,4" Radius="16" Opacity="0.25"/>
            </Grid.Shadow>
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                <Label Text="{Binding No, StringFormat='MASA {0}'}" FontSize="11" FontAttributes="Bold" TextColor="#E67E22" CharacterSpacing="4" HorizontalOptions="Center"/>
                <Label Text="{Binding No, StringFormat='Masa {0}'}" FontSize="30" FontAttributes="Bold" TextColor="#0F172A" HorizontalOptions="Center"/>
                <Label Text="{Binding KalanTutar, StringFormat='Toplam Borç: {0:N2} TL'}" FontSize="13" TextColor="#94A3B8" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <Border Grid.Column="2" BackgroundColor="#FFF7ED" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="10,8" VerticalOptions="Center">
                <Label Text="☕" FontSize="18" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" StrokeThickness="0" Margin="16,16,16,0" Padding="20,18">
            <Border.Shadow>
                <Shadow Brush="#CBD5E1" Offset="0,6" Radius="20" Opacity="0.2"/>
            </Border.Shadow>
            <Grid RowDefinitions="Auto, Auto" RowSpacing="6">
                <Label Grid.Row="0" Text="ÖDENECEK TUTAR (MANUEL GİREBİLİRSİNİZ)" FontSize="10" FontAttributes="Bold" TextColor="#94A3B8" CharacterSpacing="3" HorizontalOptions="Center"/>
                <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="4" VerticalOptions="Center">
                    <Label Text="₺" FontSize="26" FontAttributes="Bold" TextColor="#16A34A" VerticalOptions="Center" Margin="0,0,0,6"/>
                    <Entry x:Name="OdenecekTutarEntry" Text="0.00" FontSize="52" FontAttributes="Bold" TextColor="#16A34A" BackgroundColor="Transparent" HorizontalOptions="Center" HorizontalTextAlignment="Center" Keyboard="Numeric" WidthRequest="180"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Border Grid.Row="2" BackgroundColor="White" StrokeShape="RoundRectangle 24" StrokeThickness="0" Margin="16,12,16,0" Padding="4,8">
            <Border.Shadow>
                <Shadow Brush="#CBD5E1" Offset="0,6" Radius="20" Opacity="0.2"/>
            </Border.Shadow>
            <CollectionView ItemsSource="{Binding Siparisler}">
                <CollectionView.Header>
                    <HorizontalStackLayout Padding="16,8,16,4" Spacing="8">
                        <Label Text="Sipariş Kalemleri" FontSize="13" FontAttributes="Bold" TextColor="#64748B"/>
                    </HorizontalStackLayout>
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Urun">
                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="16,12" ColumnSpacing="12">

                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSecili}" Color="#E67E22" VerticalOptions="Center"/>

                            <Label Grid.Column="1" Text="{Binding Ad}" FontSize="15" FontAttributes="Bold" TextColor="#0F172A" VerticalOptions="Center" LineBreakMode="TailTruncation"/>

                            <Grid Grid.Column="2" ColumnDefinitions="40, 32, 40" VerticalOptions="Center">
                                <Border Grid.Column="0" BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 10" StrokeThickness="0" WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                                    <Button Text="−" Clicked="OdenenMiktarAzalt_Clicked" CommandParameter="{Binding .}" BackgroundColor="Transparent" TextColor="#64748B" FontSize="24" FontAttributes="Bold" Padding="0" Margin="0" VerticalOptions="Center" HorizontalOptions="Center"/>
                                </Border>

                                <Label Grid.Column="1" Text="{Binding OdenecekAdet}" VerticalOptions="Center" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="15" TextColor="#0F172A"/>

                                <Border Grid.Column="2" BackgroundColor="#FFF7ED" StrokeShape="RoundRectangle 10" StrokeThickness="0" WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                                    <Button Text="+" Clicked="OdenenMiktarArtir_Clicked" CommandParameter="{Binding .}" BackgroundColor="Transparent" TextColor="#E67E22" FontSize="24" FontAttributes="Bold" Padding="0" Margin="0" VerticalOptions="Center" HorizontalOptions="Center"/>
                                </Border>
                            </Grid>

                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="*, *" ColumnSpacing="12" Margin="16,14,16,32">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="#FEFCE8">
                <Border.Shadow>
                    <Shadow Brush="#CA8A04" Offset="0,4" Radius="14" Opacity="0.2"/>
                </Border.Shadow>
                <Button Text="💵  NAKİT" Clicked="OdemeYap_Clicked" CommandParameter="Nakit" BackgroundColor="Transparent" TextColor="#92400E" FontAttributes="Bold" FontSize="15" CharacterSpacing="1" HeightRequest="62"/>
            </Border>

            <Border Grid.Column="1" StrokeShape="RoundRectangle 18" StrokeThickness="0" BackgroundColor="#E67E22">
                <Border.Shadow>
                    <Shadow Brush="#E67E22" Offset="0,6" Radius="16" Opacity="0.35"/>
                </Border.Shadow>
                <Button Text="💳  KART" Clicked="OdemeYap_Clicked" CommandParameter="Kart" BackgroundColor="Transparent" TextColor="White" FontAttributes="Bold" FontSize="15" CharacterSpacing="1" HeightRequest="62"/>
            </Border>
        </Grid>
    </Grid>
</ContentPage>