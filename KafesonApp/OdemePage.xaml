<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.OdemePage"
             BackgroundColor="#F0F4F8"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="15" Margin="0,20,0,0">

        <Border Grid.Row="0" BackgroundColor="White" StrokeThickness="0" Padding="20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="ÖDENECEK KALAN HESAP:" TextColor="#7F8C8D" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="KalanLabel" Text="0.00 ₺" TextColor="#E74C3C" FontSize="22" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>

                <BoxView HeightRequest="1" Color="#F1F5F9" Margin="0,5"/>

                <Label Text="Manuel Tutar Gir (Opsiyonel):" TextColor="#95A5A6" FontSize="12"/>
                <Entry x:Name="AlinanTutarEntry" Keyboard="Numeric" Placeholder="Direkt tutar da yazabilirsiniz..." TextColor="#2C3E50"/>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Padding="15" Margin="0,15">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>
            <Grid RowDefinitions="Auto, *">
                <Label Grid.Row="0" Text="ÜRÜN SEÇEREK ÖDEME YAP" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,0,0,10"/>

                <CollectionView Grid.Row="1" x:Name="UrunlerView">
                    <CollectionView.EmptyView>
                        <Label Text="Ödenecek ürün bulunmuyor." TextColor="Gray" FontAttributes="Italic" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="#F8F9FA" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10" Margin="0,0,0,8">
                                <Grid ColumnDefinitions="*, Auto, Auto, Auto" BackgroundColor="Transparent">
                                    <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                        <Label Text="{Binding Ad}" FontAttributes="Bold" TextColor="#2C3E50" FontSize="15" LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding Fiyat, StringFormat='Birim: {0:N2} ₺'}" TextColor="#7F8C8D" FontSize="12"/>
                                    </VerticalStackLayout>

                                    <Button Grid.Column="1" Text="-" Clicked="Eksi_Clicked" CommandParameter="{Binding .}" WidthRequest="35" HeightRequest="35" BackgroundColor="#E74C3C" TextColor="White" CornerRadius="8" Padding="0" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding SecilenAdet, StringFormat='{0} Seçildi'}" VerticalOptions="Center" Margin="10,0" FontAttributes="Bold" TextColor="#2C3E50" WidthRequest="75" HorizontalTextAlignment="Center"/>
                                    <Button Grid.Column="3" Text="+" Clicked="Arti_Clicked" CommandParameter="{Binding .}" WidthRequest="35" HeightRequest="35" BackgroundColor="#27AE60" TextColor="White" CornerRadius="8" Padding="0" VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <Border Grid.Row="2" BackgroundColor="White" StrokeThickness="0" Padding="20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="10" Opacity="0.05"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="15">

                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="SEÇİLEN ÜRÜNLERİN TUTARI:" TextColor="#7F8C8D" FontAttributes="Bold" VerticalOptions="Center"/>
                    <Label Grid.Column="1" x:Name="SecilenTutarLabel" Text="0.00 ₺" TextColor="#3498DB" FontSize="22" FontAttributes="Bold" VerticalOptions="Center"/>
                </Grid>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">
                    <Button Grid.Column="0" Text="💵 NAKİT" Clicked="Nakit_Clicked" BackgroundColor="#27AE60" TextColor="White" FontAttributes="Bold" HeightRequest="55" CornerRadius="10"/>
                    <Button Grid.Column="1" Text="💳 KART" Clicked="Kart_Clicked" BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" HeightRequest="55" CornerRadius="10"/>
                </Grid>

                <Button Text="İptal / Geri Dön" Clicked="Iptal_Clicked" BackgroundColor="Transparent" TextColor="#E74C3C" FontAttributes="Bold" HeightRequest="40"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>