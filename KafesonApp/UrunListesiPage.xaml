<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.UrunListesiPage"
             Title="Kayıtlı Ürünler">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">
            <Label Text="KAYITLI ÜRÜNLER" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center"/>

            <VerticalStackLayout x:Name="UrunlerListesiContainer" Spacing="20" />

            <Button Text="GERİ DÖN" Clicked="GeriDon_Clicked" BackgroundColor="#95A5A6" HeightRequest="50"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>