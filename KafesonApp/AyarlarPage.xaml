<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.AyarlarPage"
             Title="Yönetim Paneli"
             BackgroundColor="#F4F7F6">

    <ContentPage.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#5E35B1"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HeightRequest" Value="50"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="{OnIdiom Phone='5,0', Desktop='0,5'}"/>
            <Setter Property="HorizontalOptions" Value="{OnIdiom Phone='Start', Desktop='Fill'}"/>
            <Setter Property="WidthRequest" Value="{OnIdiom Phone='140', Desktop='-1'}"/>
        </Style>
    </ContentPage.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{OnIdiom Phone='Auto', Desktop='*'}" />
            <RowDefinition Height="{OnIdiom Phone='*', Desktop='0'}" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone='*', Desktop='250'}" />
            <ColumnDefinition Width="{OnIdiom Phone='0', Desktop='*'}" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" 
                BackgroundColor="#2C3E50" 
                StrokeThickness="0">

            <ScrollView Orientation="{OnIdiom Phone='Horizontal', Desktop='Vertical'}"
                        VerticalScrollBarVisibility="Never" 
                        HorizontalScrollBarVisibility="Never">

                <StackLayout Orientation="{OnIdiom Phone='Horizontal', Desktop='Vertical'}" 
                             Spacing="10" 
                             Padding="15">

                    <Label Text="{OnIdiom Phone='⚙️ AYARLAR', Desktop='YÖNETİM'}" 
                           TextColor="White" 
                           FontSize="{OnIdiom Phone='16', Desktop='20'}" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"
                           Margin="{OnIdiom Phone='0,0,10,0', Desktop='0,10,0,20'}"/>

                    <Button Text="Ürün Listesi" 
                            CommandParameter="MenuListesi" 
                            Clicked="MenuSec_Clicked" 
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button Text="Yeni Ürün Ekle" 
                            CommandParameter="YeniKayit" 
                            Clicked="MenuSec_Clicked" 
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button Text="Fiyat Güncelle" 
                            CommandParameter="FiyatGuncelle" 
                            Clicked="MenuSec_Clicked" 
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button Text="Personel Kontrol" 
                            CommandParameter="PersonelKontrol" 
                            Clicked="MenuSec_Clicked" 
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button Text="Kapanan Masalar" 
                            CommandParameter="KapananMasalar" 
                            Clicked="MenuSec_Clicked" 
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button Text="Masa Düzeni" 
                            CommandParameter="MasaDuzenle" 
                            Clicked="MenuSec_Clicked" 
                            Style="{StaticResource MenuButtonStyle}"/>

                    <Button Text="Sistem Logları" 
                            CommandParameter="SistemLoglari" 
                            Clicked="MenuSec_Clicked" 
                            BackgroundColor="#8E44AD"
                            Style="{StaticResource MenuButtonStyle}"/>

                    <BoxView Color="Gray" 
                             WidthRequest="{OnIdiom Phone='1', Desktop='-1'}"
                             HeightRequest="{OnIdiom Phone='40', Desktop='1'}"
                             Margin="{OnIdiom Phone='10,0', Desktop='0,15'}"/>

                    <Button Text="Ana Menüye Dön" 
                            CommandParameter="Geri" 
                            Clicked="MenuSec_Clicked" 
                            BackgroundColor="#E74C3C" 
                            TextColor="White" 
                            HeightRequest="50" 
                            CornerRadius="8"
                            FontSize="14"
                            WidthRequest="{OnIdiom Phone='150', Desktop='-1'}"
                            Margin="{OnIdiom Phone='5,0', Desktop='0,0'}"/>

                </StackLayout>
            </ScrollView>
        </Border>

        <ContentView x:Name="ContentArea" 
                     Grid.Row="{OnIdiom Phone='1', Desktop='0'}" 
                     Grid.Column="{OnIdiom Phone='0', Desktop='1'}" 
                     Padding="{OnIdiom Phone='10', Desktop='20'}"
                     BackgroundColor="#F4F7F6">

            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <Label Text="⚙️" FontSize="{OnIdiom Phone='40', Desktop='60'}" HorizontalOptions="Center"/>
                <Label Text="Yönetim Paneli" 
                       FontSize="{OnIdiom Phone='20', Desktop='24'}" 
                       FontAttributes="Bold" 
                       TextColor="#34495E"
                       HorizontalOptions="Center"/>
                <Label Text="İşlem yapmak için menüyü kullanın." 
                       FontSize="{OnIdiom Phone='14', Desktop='16'}" 
                       TextColor="Gray"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

        </ContentView>

    </Grid>
</ContentPage>