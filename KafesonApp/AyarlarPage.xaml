<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.AyarlarPage"
             Title="Yönetim Paneli"
             BackgroundColor="#F4F7F6">

    <ContentPage.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="#5E35B1"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="HorizontalOptions" Value="Fill"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HeightRequest" Value="50"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </ContentPage.Resources>

    <Grid ColumnDefinitions="250, *">

        <Border Grid.Column="0" BackgroundColor="#2C3E50" StrokeThickness="0">
            <VerticalStackLayout Spacing="10" Padding="15">

                <Label Text="YÖNETİM" 
                       TextColor="White" 
                       FontSize="20" 
                       FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       Margin="0,10,0,20"/>

                <Button Text="Menü Listesi" 
                        CommandParameter="MenuListesi" 
                        Clicked="MenuSec_Clicked" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Text="Yeni Ürün Kayıt" 
                        CommandParameter="YeniKayit" 
                        Clicked="MenuSec_Clicked" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Text="Fiyat Ayarları" 
                        CommandParameter="FiyatGuncelle" 
                        Clicked="MenuSec_Clicked" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Text="Masa Düzeni" 
                        CommandParameter="MasaDuzenle" 
                        Clicked="MenuSec_Clicked" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <BoxView HeightRequest="1" Color="Gray" Margin="0,15"/>

                <Button Text="🏠 Ana Menüye Dön" 
                        CommandParameter="Geri" 
                        Clicked="MenuSec_Clicked" 
                        BackgroundColor="#E74C3C" 
                        TextColor="White" 
                        HeightRequest="50" 
                        CornerRadius="8"/>
            </VerticalStackLayout>
        </Border>

        <ContentView Grid.Column="1" x:Name="ContentArea" Padding="20">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <Label Text="⚙️" FontSize="60" HorizontalOptions="Center"/>
                <Label Text="Yönetim Paneline Hoş Geldiniz" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="#34495E"
                       HorizontalOptions="Center"/>
                <Label Text="İşlem yapmak için soldaki menüyü kullanın." 
                       FontSize="16" 
                       TextColor="Gray"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </ContentView>

    </Grid>
</ContentPage>