<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.AyarlarPage"
             Title="Yönetim Paneli"
             BackgroundColor="#F4F7F6">

    <Grid ColumnDefinitions="250, *">

        <Border Grid.Column="0" BackgroundColor="#2C3E50" StrokeThickness="0">
            <VerticalStackLayout Padding="15" Spacing="10">

                <Label Text="YÖNETİM" 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       FontSize="22" 
                       Margin="0,10,0,30" 
                       HorizontalOptions="Center"/>

                <Button Text="📦 Yeni Ürün Ekle" 
                        Clicked="MenuSec_Clicked" 
                        CommandParameter="UrunEkle" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Text="📋 Ürün Listesi" 
                        Clicked="MenuSec_Clicked" 
                        CommandParameter="UrunListesi" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Text="🏷️ Fiyat Güncelle" 
                        Clicked="MenuSec_Clicked" 
                        CommandParameter="FiyatGuncelle" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Text="🪑 Masa Düzeni" 
                        Clicked="MenuSec_Clicked" 
                        CommandParameter="MasaDuzenle" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Text="👥 Personel" 
                        Clicked="MenuSec_Clicked" 
                        CommandParameter="Personel" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <BoxView HeightRequest="1" Color="Gray" Margin="0,20"/>

                <Button Text="🏠 Ana Menüye Dön" 
                        Clicked="AnaSayfaDon_Clicked" 
                        BackgroundColor="#E74C3C" 
                        TextColor="White" 
                        CornerRadius="8"
                        HeightRequest="50"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>

        <ContentView Grid.Column="1" x:Name="ContentArea" Padding="20">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <Label Text="⚙️" FontSize="60" HorizontalOptions="Center"/>
                <Label Text="Yönetim Paneline Hoş Geldiniz" 
                       FontSize="24" 
                       FontAttributes="Bold" 
                       TextColor="#34495E"/>
                <Label Text="İşlem yapmak için soldaki menüyü kullanın." 
                       FontSize="16" 
                       TextColor="Gray"/>
            </VerticalStackLayout>
        </ContentView>

    </Grid>

    <ContentPage.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TextColor" Value="White"/>
            <Setter Property="HorizontalOptions" Value="Fill"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HeightRequest" Value="50"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
    </ContentPage.Resources>
</ContentPage>