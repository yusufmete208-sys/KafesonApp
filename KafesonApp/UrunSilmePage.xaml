<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.UrunSilmePage"
             Title="Ürün Yönetimi"
             BackgroundColor="#F5F6FA">

    <Grid RowDefinitions="Auto, *, Auto" RowSpacing="10" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="15">
                <Label Text="ÜRÜN SİL" FontSize="26" FontAttributes="Bold" VerticalOptions="Center" TextColor="#E74C3C"/>
                <SearchBar x:Name="UrunAramaCubugu" 
                           Grid.Column="1"
                           Placeholder="Ürün ara..." 
                           WidthRequest="250"
                           HorizontalOptions="End"
                           TextChanged="UrunArama_TextChanged" />
            </Grid>
            <BoxView HeightRequest="1" Color="Silver" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" x:Name="UrunCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="15" CornerRadius="10" HasShadow="True" BorderColor="#DCDDE1">
                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="{Binding Ad}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                                <Label Text="{Binding Kategori}" FontSize="12" TextColor="#7F8C8D"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Fiyat, StringFormat='{0:N2} TL'}" 
                                   VerticalOptions="Center" FontAttributes="Bold" TextColor="#27AE60" Margin="0,0,10,0"/>
                            <Button Grid.Column="2" Text="SİL" 
                                    Clicked="Sil_Clicked" 
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#E74C3C" 
                                    WidthRequest="60" 
                                    HeightRequest="40"
                                    FontSize="12"
                                    FontAttributes="Bold"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2" 
                Text="KAYDET VE ANA MENÜYE DÖN" 
                Clicked="GeriDon_Clicked" 
                BackgroundColor="#2C3E50" 
                TextColor="White"
                HeightRequest="55" 
                CornerRadius="10" 
                FontAttributes="Bold"
                Margin="0,10,0,0"/>
    </Grid>
</ContentPage>