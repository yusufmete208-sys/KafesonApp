<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F0F4F8">

    <Grid>
        <Border HorizontalOptions="Center" VerticalOptions="Center"
                WidthRequest="{OnIdiom Phone='320', Desktop='400'}"
                BackgroundColor="White" StrokeShape="RoundRectangle 20" 
                StrokeThickness="0" Padding="30">

            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.1"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">
                <Label Text="☕" FontSize="60" HorizontalOptions="Center"/>
                <Label Text="KAFESON" FontSize="28" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>
                <Label Text="Sisteme giriş yapmak için bilgilerinizi giriniz." FontSize="13" TextColor="#7F8C8D" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,-10,0,10"/>

                <Border BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="#E2E8F0" StrokeShape="RoundRectangle 10" Padding="15,5">
                    <Entry x:Name="KadiEntry" 
                           Placeholder="Kullanıcı Adı" 
                           TextColor="#2C3E50" 
                           ClearButtonVisibility="WhileEditing"
                           ReturnType="Next"/>
                </Border>

                <Border BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="#E2E8F0" StrokeShape="RoundRectangle 10" Padding="15,5">
                    <Entry x:Name="SifreEntry" 
                           Placeholder="Şifre" 
                           IsPassword="True" 
                           TextColor="#2C3E50" 
                           ClearButtonVisibility="WhileEditing"
                           ReturnType="Go"
                           Completed="GirisYap_Clicked"/>
                </Border>

                <Button Text="GİRİŞ YAP" Clicked="GirisYap_Clicked" 
                        BackgroundColor="#27AE60" TextColor="White" 
                        FontAttributes="Bold" FontSize="16" 
                        CornerRadius="10" HeightRequest="55" Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>