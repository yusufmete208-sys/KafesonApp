<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#F0F4F8">

    <Grid>
        <Border HorizontalOptions="Center" VerticalOptions="Center"
                WidthRequest="{OnIdiom Phone='300', Desktop='360'}"
                MaximumWidthRequest="380"
                BackgroundColor="White" StrokeShape="RoundRectangle 24" 
                StrokeThickness="0" Padding="25,30">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,12" Radius="25" Opacity="0.12"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="15">

                <Image Source="logo_kafeson.png" 
                       HeightRequest="180" 
                       WidthRequest="180" 
                       HorizontalOptions="Center" 
                       Margin="0,0,0,0"/>

                <Label Text="Sisteme giriş yapmak için bilgilerinizi giriniz." 
                       FontSize="13" TextColor="#718096" 
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" 
                       Margin="0,-5,0,5"/>

                <VerticalStackLayout Spacing="10">
                    <Border BackgroundColor="#F7FAFC" StrokeThickness="1" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="15,5">
                        <Entry x:Name="KadiEntry" 
                               Placeholder="Kullanıcı Adı" 
                               TextColor="#2D3748" 
                               PlaceholderColor="#A0AEC0"
                               ClearButtonVisibility="WhileEditing"/>
                    </Border>

                    <Border BackgroundColor="#F7FAFC" StrokeThickness="1" Stroke="#E2E8F0" StrokeShape="RoundRectangle 12" Padding="15,5">
                        <Entry x:Name="SifreEntry" 
                               Placeholder="Şifre" 
                               IsPassword="True" 
                               TextColor="#2D3748" 
                               PlaceholderColor="#A0AEC0"
                               ClearButtonVisibility="WhileEditing"
                               Completed="GirisYap_Clicked"/>
                    </Border>
                </VerticalStackLayout>

                <Button Text="GİRİŞ YAP" Clicked="GirisYap_Clicked" 
                        BackgroundColor="#27AE60" TextColor="White" 
                        FontAttributes="Bold" FontSize="16" 
                        CornerRadius="12" HeightRequest="55" Margin="0,10,0,0">
                    <Button.Shadow>
                        <Shadow Brush="#27AE60" Offset="0,4" Opacity="0.3" Radius="8"/>
                    </Button.Shadow>
                </Button>

                <Label Text="Şifremi Unuttum" 
                       TextColor="#718096" 
                       FontSize="13" 
                       HorizontalOptions="Center" 
                       Margin="0,5,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="SifremiUnuttum_Tapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>