<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Kafeson.Shared.Models;assembly=Kafeson.Shared"
             x:Class="KafesonApp.MenuGosterimView">

    <Grid RowDefinitions="Auto, *" Padding="15">

        <Label Grid.Row="0" Text="📦 MENÜ LİSTESİ" FontAttributes="Bold" FontSize="20" TextColor="#2C3E50" Margin="0,0,0,15"/>

        <CollectionView Grid.Row="1" x:Name="UrunListesi">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Urun">
                    <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeShape="RoundRectangle 10" Padding="10" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding Ad}" FontAttributes="Bold" TextColor="#2C3E50"/>
                                <Label Text="{Binding Kategori}" FontSize="12" TextColor="Gray"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="1" Text="{Binding Fiyat, StringFormat='{0:N2} ₺'}" 
                                   TextColor="#27AE60" FontAttributes="Bold" VerticalOptions="Center" Margin="10,0"/>

                            <Button Grid.Column="2" Text="🗑" BackgroundColor="Transparent" TextColor="#E74C3C" 
                                    FontSize="18" Clicked="OnUrunSilClicked" CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>