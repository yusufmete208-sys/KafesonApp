<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.SatisDetayPage"
             Title="SATIŞ DETAYI"
             BackgroundColor="#F4F7F6">

    <Grid RowDefinitions="Auto, *, Auto">

        <Frame Grid.Row="0" BackgroundColor="#2C3E50" CornerRadius="0" Padding="15" HasShadow="False">
            <VerticalStackLayout Spacing="5" HorizontalOptions="Start">
                <Label x:Name="MasaBaslikLabel" TextColor="White" FontSize="20" FontAttributes="Bold"/>
                <Label x:Name="ZamanLabel" TextColor="#BDC3C7" FontSize="14"/>
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="1" x:Name="UrunlerListesi" Margin="15">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, Auto" Padding="10">
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label Text="{Binding Miktar, StringFormat='{0}x'}" FontAttributes="Bold" TextColor="#2980B9" FontSize="16"/>
                            <Label Text="{Binding Ad}" TextColor="#2C3E50" FontSize="16"/>
                        </HorizontalStackLayout>

                        <Label Grid.Column="1" 
                               Text="{Binding ToplamFiyat, StringFormat='{0:N2} TL'}" 
                               TextColor="#2C3E50" 
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Frame Grid.Row="2" BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True" Margin="0">
            <VerticalStackLayout Spacing="12" HorizontalOptions="Fill">

                <HorizontalStackLayout Spacing="10">
                    <Label Text="Nakit Ödeme:" TextColor="Gray" FontSize="14" WidthRequest="100"/>
                    <Label x:Name="NakitLabel" FontAttributes="Bold" TextColor="#34495E" FontSize="14"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="10">
                    <Label Text="Kart Ödeme:" TextColor="Gray" FontSize="14" WidthRequest="100"/>
                    <Label x:Name="KartLabel" FontAttributes="Bold" TextColor="#34495E" FontSize="14"/>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="#ECF0F1" Margin="0,5" HorizontalOptions="Fill"/>

                <Label x:Name="ToplamLabel" FontSize="26" FontAttributes="Bold" TextColor="#27AE60" HorizontalOptions="Start"/>

                <Button Text="KAPAT" 
                        Clicked="Kapat_Clicked" 
                        BackgroundColor="#E74C3C" 
                        TextColor="White" 
                        FontAttributes="Bold"
                        CornerRadius="10"
                        HeightRequest="50"
                        HorizontalOptions="Fill"
                        Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>