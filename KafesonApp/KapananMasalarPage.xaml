<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KafesonApp.Models"
             x:Class="KafesonApp.KapananMasalar1View"
             Title="Satış Geçmişi"
             BackgroundColor="#F0F4F8"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, Auto, *">

        <Border Grid.Row="0" BackgroundColor="#1E293B" StrokeThickness="0" Padding="15,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Text="← Geri Dön" Clicked="GeriDon_Clicked" BackgroundColor="#E74C3C" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="40" Padding="15,0"/>
                <Label Grid.Column="1" Text="GEÇMİŞ ADİSYONLAR" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Margin="15,15,15,5" Padding="15">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="10">
                <Label Text="🔍 Filtreleme Seçenekleri" FontAttributes="Bold" TextColor="#7F8C8D" FontSize="12" Margin="0,0,0,5"/>

                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" ColumnSpacing="15" RowSpacing="10">
                    <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#F8F9FA" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <DatePicker x:Name="TarihFiltre" DateSelected="Filtre_Changed" TextColor="#2C3E50" Margin="5,0"/>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#F8F9FA" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Entry x:Name="MasaFiltre" Placeholder="Masa No" Keyboard="Numeric" TextChanged="Filtre_Changed" TextColor="#2C3E50" Margin="10,0"/>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#F8F9FA" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Picker x:Name="OdemeFiltre" Title="Ödeme Yöntemi" SelectedIndexChanged="Filtre_Changed" TextColor="#2C3E50" Margin="10,0"/>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#F8F9FA" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                        <Picker x:Name="PersonelFiltre" Title="Personel Seç" SelectedIndexChanged="Filtre_Changed" TextColor="#2C3E50" Margin="10,0"/>
                    </Border>
                </Grid>

                <Button Text="Filtreleri Temizle" Clicked="Temizle_Clicked" BackgroundColor="#ECF0F1" TextColor="#2C3E50" FontAttributes="Bold" CornerRadius="8" HeightRequest="35" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="2" x:Name="KapananMasalarListesi" Margin="15,5,15,0">
            <CollectionView.EmptyView>
                <Label Text="Bu kriterlere uygun kayıt bulunamadı." TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SatisRaporu">
                    <Border Margin="0,5,0,10" BackgroundColor="White" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMasaTapped" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                <Label Text="{Binding MasaNo, StringFormat='MASA {0}'}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                                <Label Text="{Binding PersonelAdi, StringFormat='Personel: {0}'}" FontSize="12" TextColor="#3498DB" FontAttributes="Bold"/>
                            </VerticalStackLayout>

                            <Label Grid.Row="0" Grid.Column="1" Text="{Binding Tutar, StringFormat='{0:N2} ₺'}" FontSize="20" FontAttributes="Bold" TextColor="#27AE60" VerticalOptions="Center"/>

                            <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="#F1F5F9" Margin="0,10"/>

                            <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="15">
                                <Label Text="{Binding Tarih, StringFormat='🕒 {0:HH:mm}'}" TextColor="#7F8C8D" FontSize="13" VerticalOptions="Center"/>
                                <Label Text="{Binding OdemeTuru}" TextColor="#8E44AD" FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>