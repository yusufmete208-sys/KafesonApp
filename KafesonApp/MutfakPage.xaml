<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KafesonApp.Models"
             x:Class="KafesonApp.MutfakPage"
             Title="Mutfak / Hazırlanacaklar"
             BackgroundColor="#2C3E50">
    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" BackgroundColor="#E67E22" Padding="15" ColumnDefinitions="*, Auto">
            <Label Text="HAZIRLANACAK SİPARİŞLER" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
            <Button Grid.Column="1" Text="Yenile" Clicked="Yenile_Clicked" BackgroundColor="Transparent" TextColor="White" BorderColor="White" BorderWidth="1" HeightRequest="35"/>
        </Grid>

        <CollectionView Grid.Row="1" x:Name="MutfakListesiView" Margin="10">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                    <Label Text="☕" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="Bekleyen sipariş yok. Mutfak rahat!" TextColor="#BDC3C7" FontSize="18"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="{OnIdiom Phone='1', Desktop='3'}" HorizontalItemSpacing="10" VerticalItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MutfakSiparisi">
                    <Border BackgroundColor="#ECF0F1" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="15">
                        <Grid ColumnDefinitions="Auto, *, Auto">

                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" BackgroundColor="#34495E" Padding="10" WidthRequest="70">
                                <Label Text="{Binding MasaNo, StringFormat='MASA {0}'}" TextColor="White" FontAttributes="Bold" HorizontalOptions="Center" FontSize="12"/>
                                <Label Text="{Binding SaatMetni}" TextColor="#F1C40F" FontAttributes="Bold" HorizontalOptions="Center" FontSize="14"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                                <Label Text="{Binding Miktar, StringFormat='{0} ADET'}" TextColor="#E74C3C" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="{Binding UrunAd}" TextColor="#2C3E50" FontAttributes="Bold" FontSize="20" LineBreakMode="WordWrap"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="2" Text="HAZIR ✓" 
                                    Clicked="Hazir_Clicked" CommandParameter="{Binding .}" 
                                    BackgroundColor="#27AE60" TextColor="White" 
                                    FontAttributes="Bold" WidthRequest="90" HeightRequest="50" 
                                    CornerRadius="8" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>