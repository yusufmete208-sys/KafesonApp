<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.BaglantiAyarView">

    <ScrollView BackgroundColor="#F8FAFC">
        <VerticalStackLayout Padding="30" Spacing="20" HorizontalOptions="Center" VerticalOptions="Center">

            <Border BackgroundColor="White" Padding="25" StrokeShape="RoundRectangle 20" Stroke="#E2E8F0" StrokeThickness="1" WidthRequest="400">
                <VerticalStackLayout Spacing="15">
                    <Label Text="🌐 Sunucu IP Ayarı" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center"/>
                    <Label Text="Bilgisayarınızın (Sunucu) IP adresini girin." FontSize="13" TextColor="#64748B" HorizontalOptions="Center"/>

                    <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 12" Stroke="#E2E8F0" StrokeThickness="1" Padding="15,0">
                        <Entry x:Name="IpEntry" 
                               Placeholder="Örn: 192.168.1.108" 
                               PlaceholderColor="#94A3B8" 
                               TextColor="#1E293B" 
                               BackgroundColor="Transparent"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>
                    </Border>

                    <Button Text="💾 KAYDET VE BAĞLAN" Clicked="Kaydet_Clicked" BackgroundColor="#22C55E" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="50" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White" Padding="25" StrokeShape="RoundRectangle 20" Stroke="#E2E8F0" StrokeThickness="1" WidthRequest="400">
                <VerticalStackLayout Spacing="15" HorizontalOptions="Center">
                    <Label Text="📱 Dijital Menü QR Kodu" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center"/>
                    <Label Text="Müşterilerin masadan menüyü görebilmesi için:" FontSize="13" TextColor="#64748B" HorizontalOptions="Center"/>

                    <Border Stroke="#E2E8F0" StrokeThickness="2" StrokeShape="RoundRectangle 15" BackgroundColor="White" Padding="10">
                        <Image x:Name="QrImage" WidthRequest="200" HeightRequest="200" BackgroundColor="White"/>
                    </Border>

                    <Button Text="🖨️ QR KODU YAZDIR" Clicked="QrYazdir_Clicked" BackgroundColor="#3B82F6" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="50" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>