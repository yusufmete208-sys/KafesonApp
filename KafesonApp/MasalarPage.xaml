<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.MasalarPage"
             Title="Masa Planı"
             BackgroundColor="#F4F7F6">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="#2C3E50" Padding="10" StrokeThickness="0">
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="15">
                <Button x:Name="BtnIcMekan" 
                        Text="İÇ MEKAN" 
                        Clicked="MekanSec_Clicked" 
                        CommandParameter="İç Mekan"
                        BackgroundColor="#3498DB" 
                        TextColor="White" 
                        WidthRequest="140" 
                        HeightRequest="45"
                        CornerRadius="10"
                        FontAttributes="Bold"/>

                <Button x:Name="BtnBahce" 
                        Text="BAHÇE" 
                        Clicked="MekanSec_Clicked" 
                        CommandParameter="Bahçe"
                        BackgroundColor="#34495E" 
                        TextColor="#BDC3C7" 
                        WidthRequest="140" 
                        HeightRequest="45"
                        CornerRadius="10"
                        FontAttributes="Bold"/>
            </HorizontalStackLayout>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <FlexLayout x:Name="MasalarContainer" 
                            Wrap="Wrap" 
                            JustifyContent="Center" 
                            AlignItems="Center" 
                            AlignContent="Start"
                            MinimumHeightRequest="400">
                </FlexLayout>

                <HorizontalStackLayout HorizontalOptions="Center" Spacing="20" Margin="0,20,0,10">
                    <HorizontalStackLayout Spacing="5">
                        <BoxView Color="#2ECC71" WidthRequest="15" HeightRequest="15" CornerRadius="3"/>
                        <Label Text="Boş" FontSize="12" TextColor="#2C3E50"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <BoxView Color="#E74C3C" WidthRequest="15" HeightRequest="15" CornerRadius="3"/>
                        <Label Text="Dolu" FontSize="12" TextColor="#2C3E50"/>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

                <Button Text="ANA MENÜYE GİT" 
                        Clicked="AnaMenuyeGit_Clicked"
                        BackgroundColor="#34495E" 
                        TextColor="White" 
                        CornerRadius="20"
                        HeightRequest="50"
                        WidthRequest="200"
                        HorizontalOptions="Center"
                        Margin="0,20"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>