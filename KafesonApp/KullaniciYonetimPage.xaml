<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KafesonApp.Models"
             x:Class="KafesonApp.KullaniciYonetimPage"
             Title="Personel Kontrol"
             BackgroundColor="#F0F4F8">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="20">

        <Grid Grid.Row="0">

            <Border x:Name="YeniPersonelFormu" BackgroundColor="White" StrokeShape="RoundRectangle 15" StrokeThickness="0" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">
                    <Label Text="➕ Yeni Personel Ekle" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Border Grid.Column="0" BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="#E2E8F0" StrokeShape="RoundRectangle 8">
                            <Entry x:Name="YeniKadiEntry" Placeholder="Kullanıcı Adı" Margin="10,0" TextColor="#2C3E50"/>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#F8F9FA" StrokeThickness="1" Stroke="#E2E8F0" StrokeShape="RoundRectangle 8">
                            <Entry x:Name="YeniSifreEntry" Placeholder="Şifre Belirle" Margin="10,0" TextColor="#2C3E50"/>
                        </Border>
                    </Grid>

                    <Label Text="Personel Yetkileri:" TextColor="#7F8C8D" FontSize="12" Margin="0,5,0,0"/>
                    <FlexLayout Wrap="Wrap" JustifyContent="SpaceBetween" AlignItems="Center">
                        <HorizontalStackLayout Spacing="5" Margin="0,0,15,0">
                            <CheckBox x:Name="ChkMasa" IsChecked="True" Color="#27AE60"/>
                            <Label Text="Sipariş Alabilir" VerticalOptions="Center" TextColor="#2C3E50"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="5" Margin="0,0,15,0">
                            <CheckBox x:Name="ChkRapor" Color="#27AE60"/>
                            <Label Text="Rapor Görebilir" VerticalOptions="Center" TextColor="#2C3E50"/>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="5">
                            <CheckBox x:Name="ChkAyarlar" Color="#27AE60"/>
                            <Label Text="Yönetici (Tam Yetki)" VerticalOptions="Center" TextColor="#2C3E50"/>
                        </HorizontalStackLayout>
                    </FlexLayout>

                    <Button Text="Kaydet ve Sisteme Ekle" Clicked="PersonelEkle_Clicked" BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="45" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>

            <Border x:Name="PerformansPaneli" IsVisible="False" BackgroundColor="#1E293B" StrokeShape="RoundRectangle 15" StrokeThickness="0" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,6" Radius="15" Opacity="0.2"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label x:Name="PerfKullaniciLabel" Text="PERSONEL PERFORMANSI" FontSize="18" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="✖ Kapat" Clicked="PerformansKapat_Clicked" BackgroundColor="#EF4444" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="35" Padding="15,0"/>
                    </Grid>

                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="10">
                        <Border Grid.Column="0" BackgroundColor="#334155" StrokeThickness="0" Padding="10" StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="TOPLAM CİRO" FontSize="10" TextColor="#94A3B8" HorizontalOptions="Center"/>
                                <Label x:Name="PerfCiroLabel" Text="0.00 ₺" FontSize="18" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#334155" StrokeThickness="0" Padding="10" StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="İŞLEM" FontSize="10" TextColor="#94A3B8" HorizontalOptions="Center"/>
                                <Label x:Name="PerfIslemLabel" Text="0" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#334155" StrokeThickness="0" Padding="10" StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="ORT. SEPET" FontSize="10" TextColor="#94A3B8" HorizontalOptions="Center"/>
                                <Label x:Name="PerfOrtalamaLabel" Text="0.00 ₺" FontSize="18" FontAttributes="Bold" TextColor="#F59E0B" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Label Text="Son İşlemleri:" TextColor="#94A3B8" FontSize="12" Margin="0,5,0,0"/>
                    <CollectionView x:Name="PerfIslemlerListesi" HeightRequest="120">
                        <CollectionView.EmptyView>
                            <Label Text="Kayıtlı satışı yok." TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SatisRaporu">
                                <Grid ColumnDefinitions="*, Auto, Auto" Padding="5,10" BackgroundColor="#0F172A" Margin="0,0,0,5">
                                    <Label Grid.Column="0" Text="{Binding MasaNo, StringFormat='Masa {0}'}" TextColor="White" FontAttributes="Bold" VerticalOptions="Center"/>
                                    <Label Grid.Column="1" Text="{Binding Tarih, StringFormat='{0:HH:mm}'}" TextColor="#94A3B8" Margin="0,0,15,0" VerticalOptions="Center"/>
                                    <Label Grid.Column="2" Text="{Binding Tutar, StringFormat='{0:N2} ₺'}" TextColor="#10B981" FontAttributes="Bold" VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <CollectionView Grid.Row="1" x:Name="PersonelListesiView">
            <CollectionView.Header>
                <Label Text="Kayıtlı Personeller" FontAttributes="Bold" TextColor="#7F8C8D" Margin="0,0,0,10"/>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Kullanici">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="15" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="*, Auto, Auto">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                                <Label Text="{Binding KullaniciAdi}" FontAttributes="Bold" FontSize="16" TextColor="#2C3E50"/>
                                <Label Text="{Binding Sifre, StringFormat='Şifre: {0}'}" FontSize="12" TextColor="#95A5A6"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="1" Text="📊 Performans" Clicked="PersonelPerformans_Clicked" CommandParameter="{Binding .}" BackgroundColor="#10B981" TextColor="White" HeightRequest="35" Padding="15,0" CornerRadius="8" Margin="0,0,10,0" VerticalOptions="Center"/>

                            <Button Grid.Column="2" Text="Sil" Clicked="PersonelSil_Clicked" CommandParameter="{Binding .}" BackgroundColor="#EF4444" TextColor="White" HeightRequest="35" Padding="15,0" CornerRadius="8" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>