<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.FiyatRevizeView">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="15">

        <ScrollView Grid.Row="0" Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
            <HorizontalStackLayout x:Name="KatMenuStack" Spacing="10">
            </HorizontalStackLayout>
        </ScrollView>

        <CollectionView Grid.Row="1" x:Name="FiyatListeView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" Padding="10" BorderColor="#DCDDE1">
                        <Grid ColumnDefinitions="*, 120, Auto">
                            <Label Text="{Binding Ad}" VerticalOptions="Center" FontAttributes="Bold"/>

                            <Entry Grid.Column="1" 
                                   Text="{Binding Fiyat, Mode=TwoWay}" 
                                   Keyboard="Numeric" 
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center"/>

                            <Button Grid.Column="2" 
                                    Text="GÜNCELLE" 
                                    Clicked="OnFiyatGuncelleClicked"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#9B59B6" 
                                    TextColor="White" 
                                    Margin="10,0,0,0"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>