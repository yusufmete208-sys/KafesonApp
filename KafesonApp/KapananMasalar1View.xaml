<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.KapananMasalar1View">

    <Grid RowDefinitions="Auto, *" BackgroundColor="#F0F3F4">
        <Frame Grid.Row="0" BackgroundColor="#2C3E50" CornerRadius="0" Padding="15">
            <Label Text="GÜNLÜK SATIŞ GEÇMİŞİ" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
        </Frame>

        <CollectionView Grid.Row="1" x:Name="KapananMasalarListesi" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#D5D8DC" CornerRadius="12" HasShadow="True" Padding="15" Margin="0,5" BackgroundColor="White">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding MasaNo, StringFormat='Masa {0}'}" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50"/>
                                <Label Grid.Column="1" Text="{Binding ToplamTutar, StringFormat='{0:N2} TL'}" FontSize="18" FontAttributes="Bold" TextColor="#27AE60"/>
                            </Grid>

                            <Label Text="{Binding KapanisZamani, StringFormat='Kapanış: {0:HH:mm}'}" FontSize="12" TextColor="Gray"/>

                            <BoxView HeightRequest="1" Color="#ECF0F1" Margin="0,5"/>

                            <Label Text="Satılan Ürünler:" FontSize="13" FontAttributes="Bold" TextColor="#7F8C8D"/>
                            <StackLayout BindableLayout.ItemsSource="{Binding Urunler}" Spacing="2">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*, Auto" Padding="0,2">
                                            <Label Text="{Binding Ad}" FontSize="13" TextColor="#34495E" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding Miktar, StringFormat='x{0}'}" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>