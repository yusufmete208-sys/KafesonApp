<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.SiparisPage"
             xmlns:models="clr-namespace:KafesonApp.Models"
             Title="Sipariş Paneli"
             BackgroundColor="#F4F7F6"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone='*', Desktop='220'}" />
            <ColumnDefinition Width="{OnIdiom Phone='0', Desktop='*'}" />
            <ColumnDefinition Width="{OnIdiom Phone='0', Desktop='380'}" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" 
                Grid.Column="0" 
                Grid.RowSpan="{OnIdiom Phone='1', Desktop='3'}"
                BackgroundColor="#1E293B" StrokeThickness="0" 
                Margin="{OnIdiom Phone='0', Desktop='0,0,5,0'}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="{OnIdiom Phone='0,0,15,15', Desktop='0, 20, 20, 0'}"/>
            </Border.StrokeShape>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{OnIdiom Phone='0', Desktop='Auto'}" />
                    <RowDefinition Height="{OnIdiom Phone='95', Desktop='*'}" />
                </Grid.RowDefinitions>

                <VerticalStackLayout Grid.Row="0" Padding="15,30,15,20" HorizontalOptions="Center"
                                     IsVisible="{OnIdiom Phone='False', Desktop='True'}">
                    <Label Text="🍽️" FontSize="40" HorizontalOptions="Center"/>
                    <Label Text="MENÜ" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="1"
                            Orientation="{OnIdiom Phone='Horizontal', Desktop='Vertical'}"
                            VerticalScrollBarVisibility="Never" HorizontalScrollBarVisibility="Never">

                    <StackLayout x:Name="KategoriContainer" 
                                 Orientation="{OnIdiom Phone='Horizontal', Desktop='Vertical'}"
                                 Spacing="10" 
                                 Padding="{OnIdiom Phone='15,15,15,5', Desktop='15,0,15,15'}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Start"/>
                </ScrollView>
            </Grid>
        </Border>

        <ScrollView Grid.Row="{OnIdiom Phone='1', Desktop='0'}" 
                    Grid.Column="{OnIdiom Phone='0', Desktop='1'}" 
                    Grid.RowSpan="{OnIdiom Phone='1', Desktop='3'}"
                    Padding="{OnIdiom Phone='10,15', Desktop='15'}">
            <FlexLayout x:Name="UrunlerContainer" 
                        Wrap="Wrap" 
                        JustifyContent="{OnIdiom Phone='SpaceEvenly', Desktop='Start'}" 
                        AlignContent="Start" 
                        AlignItems="Start" />
        </ScrollView>

        <Border Grid.Row="{OnIdiom Phone='2', Desktop='0'}" 
                Grid.Column="{OnIdiom Phone='0', Desktop='2'}" 
                Grid.RowSpan="{OnIdiom Phone='1', Desktop='3'}"
                BackgroundColor="White" StrokeThickness="0" 
                Margin="{OnIdiom Phone='0', Desktop='5,15,15,15'}" 
                Padding="{OnIdiom Phone='15,10,15,15', Desktop='20'}">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="{OnIdiom Phone='25,25,0,0', Desktop='20'}"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-5" Radius="20" Opacity="0.1"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto, *, Auto">

                <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,10">
                    <Border BackgroundColor="#34495E" StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="10,5" VerticalOptions="Center">
                        <Label Text="{Binding SecilenMasa.No, StringFormat='MASA {0}'}" TextColor="White" FontAttributes="Bold" FontSize="{OnIdiom Phone='12', Desktop='16'}"/>
                    </Border>

                    <Label Grid.Column="1" Text="ADİSYON" FontAttributes="Bold" FontSize="{OnIdiom Phone='16', Desktop='20'}" TextColor="#2C3E50" HorizontalOptions="Center" VerticalOptions="Center"/>

                    <Button Grid.Column="2" Text="✖ Kapat" Clicked="GeriDonTiklandi" BackgroundColor="#E74C3C" TextColor="White" FontAttributes="Bold" HeightRequest="35" Padding="10,0" CornerRadius="8"/>
                </Grid>

                <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never" HeightRequest="{OnIdiom Phone='140', Desktop='-1'}">
                    <VerticalStackLayout Spacing="10">

                        <CollectionView ItemsSource="{Binding SecilenMasa.Sepet}">
                            <CollectionView.EmptyView>
                                <Label Text="Sepet boş." TextColor="Gray" FontAttributes="Italic" HorizontalOptions="Center" Margin="10"/>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Urun">
                                    <Border BackgroundColor="#FFF9F4" StrokeThickness="1" Stroke="#FAD7A1" StrokeShape="RoundRectangle 10" Padding="8" Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="*, Auto, Auto">
                                            <Label Grid.Column="0" Text="{Binding Ad}" TextColor="#2C3E50" FontAttributes="Bold" FontSize="13" VerticalOptions="Center" LineBreakMode="TailTruncation" Margin="0,0,5,0"/>

                                            <Border Grid.Column="1" BackgroundColor="White" StrokeThickness="1" Stroke="#E2E8F0" StrokeShape="RoundRectangle 8" Padding="2" Margin="0,0,10,0">
                                                <HorizontalStackLayout Spacing="2">
                                                    <Button Text="-" Clicked="SilTiklandi" CommandParameter="{Binding .}" BackgroundColor="#E74C3C" TextColor="White" WidthRequest="28" HeightRequest="28" Padding="0" CornerRadius="5"/>
                                                    <Label Text="{Binding Miktar}" TextColor="#2C3E50" VerticalOptions="Center" FontAttributes="Bold" FontSize="16" WidthRequest="25" HorizontalTextAlignment="Center"/>
                                                    <Button Text="+" Clicked="MiktarArtir_Clicked" CommandParameter="{Binding .}" BackgroundColor="#27AE60" TextColor="White" WidthRequest="28" HeightRequest="28" Padding="0" CornerRadius="5"/>
                                                </HorizontalStackLayout>
                                            </Border>

                                            <Label Grid.Column="2" Text="{Binding ToplamFiyat, StringFormat='{0:N2} ₺'}" TextColor="#E67E22" VerticalOptions="Center" FontAttributes="Bold" FontSize="14"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <CollectionView ItemsSource="{Binding SecilenMasa.Siparisler}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Urun">
                                    <Grid ColumnDefinitions="30, *, Auto" Padding="5,5" Margin="0,0,0,2">
                                        <Label Grid.Column="0" Text="{Binding Miktar, StringFormat='{0}x'}" TextColor="#27AE60" FontAttributes="Bold" VerticalOptions="Center"/>
                                        <Label Grid.Column="1" Text="{Binding Ad}" TextColor="#7F8C8D" FontSize="13" VerticalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding ToplamFiyat, StringFormat='{0:N2} ₺'}" TextColor="#7F8C8D" FontSize="13" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2" Spacing="8" Padding="0,10,0,0">
                    <BoxView HeightRequest="1" Color="#E2E8F0"/>

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="TOPLAM TUTAR:" FontAttributes="Bold" FontSize="14" TextColor="#7F8C8D" VerticalOptions="Center"/>
                        <Label Grid.Column="1" x:Name="ToplamLabel" Text="0.00 ₺" FontSize="{OnIdiom Phone='20', Desktop='22'}" FontAttributes="Bold" TextColor="#27AE60"/>
                    </Grid>

                    <Button x:Name="AnaButon" HeightRequest="50" FontSize="16" FontAttributes="Bold" TextColor="White" CornerRadius="12" Clicked="AnaButon_Clicked">
                        <Button.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.2"/>
                        </Button.Shadow>
                    </Button>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Margin="0,5,0,0">
                        <Button Grid.Column="0" Text="Masa Aktar" Clicked="MasaAktar_Clicked" BackgroundColor="#F1C40F" TextColor="#2C3E50" FontAttributes="Bold" HeightRequest="{OnIdiom Phone='40', Desktop='45'}" CornerRadius="10" FontSize="{OnIdiom Phone='12', Desktop='14'}"/>
                        <Button Grid.Column="1" Text="Birleştir" Clicked="MasaBirlestir_Clicked" BackgroundColor="#9B59B6" TextColor="White" FontAttributes="Bold" HeightRequest="{OnIdiom Phone='40', Desktop='45'}" CornerRadius="10" FontSize="{OnIdiom Phone='12', Desktop='14'}"/>
                    </Grid>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>  