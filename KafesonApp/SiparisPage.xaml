<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Kafeson.Shared.Models;assembly=Kafeson.Shared"
             x:Class="KafesonApp.SiparisPage"
             Title=""
             BackgroundColor="#F4F6FB"
             NavigationPage.HasNavigationBar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="{OnIdiom Phone='Auto', Desktop='*'}" />
            <RowDefinition Height="{OnIdiom Phone='*', Desktop='0'}" />
            <RowDefinition Height="{OnIdiom Phone='Auto', Desktop='0'}" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{OnIdiom Phone='*', Desktop='200'}" />
            <ColumnDefinition Width="{OnIdiom Phone='0', Desktop='*'}" />
            <ColumnDefinition Width="{OnIdiom Phone='0', Desktop='360'}" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="{OnIdiom Phone='1', Desktop='3'}"
                BackgroundColor="White" StrokeThickness="0"
                Margin="{OnIdiom Phone='0,0,0,10', Desktop='0'}">
            <Border.Shadow>
                <Shadow Brush="#CBD5E1" Offset="{OnIdiom Phone='0,2', Desktop='4,0'}" Radius="{OnIdiom Phone='8', Desktop='16'}" Opacity="0.15"/>
            </Border.Shadow>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="{OnIdiom Phone='*', Desktop='Auto'}"/>
                    <RowDefinition Height="{OnIdiom Phone='0', Desktop='*'}"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{OnIdiom Phone='Auto', Desktop='*'}"/>
                    <ColumnDefinition Width="{OnIdiom Phone='*', Desktop='0'}"/>
                </Grid.ColumnDefinitions>

                <VerticalStackLayout Grid.Row="0" Grid.Column="0" 
                                     Padding="{OnIdiom Phone='10,10,10,10', Desktop='16,48,16,16'}"
                                     Spacing="4" VerticalOptions="Center">
                    <Border BackgroundColor="#E67E22" StrokeShape="RoundRectangle 14" StrokeThickness="0" 
                            WidthRequest="{OnIdiom Phone='40', Desktop='44'}" HeightRequest="{OnIdiom Phone='40', Desktop='44'}" HorizontalOptions="Center">
                        <Label Text="🍽️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="MENÜ" FontSize="12" FontAttributes="Bold" TextColor="#E67E22" CharacterSpacing="3" 
                           HorizontalOptions="Center" IsVisible="{OnIdiom Phone='False', Desktop='True'}"/>
                </VerticalStackLayout>

                <ScrollView Grid.Row="{OnIdiom Phone='0', Desktop='1'}" Grid.Column="{OnIdiom Phone='1', Desktop='0'}" 
                            Orientation="{OnIdiom Phone='Horizontal', Desktop='Vertical'}" 
                            VerticalScrollBarVisibility="Never" HorizontalScrollBarVisibility="Never"
                            VerticalOptions="Center" Margin="{OnIdiom Phone='0', Desktop='0,10,0,0'}">
                    <StackLayout x:Name="KategoriContainer" 
                                 Orientation="{OnIdiom Phone='Horizontal', Desktop='Vertical'}"
                                 Spacing="6" 
                                 Padding="{OnIdiom Phone='10,10,15,10', Desktop='10,0,10,16'}"/>
                </ScrollView>
            </Grid>
        </Border>

        <ScrollView Grid.Row="{OnIdiom Phone='1', Desktop='0'}" Grid.Column="{OnIdiom Phone='0', Desktop='1'}" 
                    Grid.RowSpan="{OnIdiom Phone='1', Desktop='3'}"
                    Padding="{OnIdiom Phone='12', Desktop='16'}" BackgroundColor="#F4F6FB">
            <FlexLayout x:Name="UrunlerContainer" Wrap="Wrap" 
                        JustifyContent="{OnIdiom Phone='SpaceAround', Desktop='Start'}" 
                        AlignContent="Start"/>
        </ScrollView>

        <Border Grid.Row="{OnIdiom Phone='2', Desktop='0'}" Grid.Column="{OnIdiom Phone='0', Desktop='2'}" 
                Grid.RowSpan="{OnIdiom Phone='1', Desktop='3'}"
                BackgroundColor="White" StrokeThickness="0"
                Margin="{OnIdiom Phone='0', Desktop='8,14,14,14'}">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="{OnIdiom Phone='24,24,0,0', Desktop='22'}"/>
            </Border.StrokeShape>

            <Border.Shadow>
                <Shadow Brush="#CBD5E1" Offset="{OnIdiom Phone='0,-4', Desktop='0,4'}" Radius="20" Opacity="0.18"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto, *, Auto" Padding="{OnIdiom Phone='16,16,16,20', Desktop='16,16,16,16'}">

                <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,14">
                    <Border BackgroundColor="#0F172A" StrokeShape="RoundRectangle 10" StrokeThickness="0" Padding="12,7" VerticalOptions="Center">
                        <Label Text="{Binding SecilenMasa.No, StringFormat='MASA {0}'}" TextColor="White" FontAttributes="Bold" FontSize="13" CharacterSpacing="1"/>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="#FEF2F2" StrokeShape="RoundRectangle 10" Stroke="#FECACA" StrokeThickness="1" Padding="0" VerticalOptions="Center">
                        <Button Text="✕  Kapat" Clicked="GeriDonTiklandi" BackgroundColor="Transparent" TextColor="#DC2626" FontAttributes="Bold" FontSize="12" Padding="12,6" HeightRequest="36"/>
                    </Border>
                </Grid>

                <ScrollView Grid.Row="1" MaximumHeightRequest="{OnIdiom Phone='200', Desktop='3000'}">
                    <VerticalStackLayout Spacing="0">

                        <CollectionView ItemsSource="{Binding SecilenMasa.Sepet}">
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Padding="0,20" Spacing="6" HorizontalOptions="Center">
                                    <Label Text="🛒" FontSize="32" HorizontalOptions="Center"/>
                                    <Label Text="Sepet boş" FontSize="13" TextColor="#CBD5E1" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Urun">
                                    <Border BackgroundColor="#FFF7ED" Stroke="#FDBA74" StrokeShape="RoundRectangle 12" StrokeThickness="2" Padding="{OnIdiom Phone='12,16', Desktop='16,22'}" Margin="0,0,0,12">
                                        <Grid ColumnDefinitions="*, Auto, Auto" ColumnSpacing="10">

                                            <Label Text="{Binding Ad}" TextColor="#0F172A" FontAttributes="Bold" FontSize="{OnIdiom Phone='14', Desktop='16'}" VerticalOptions="Center" LineBreakMode="TailTruncation"/>

                                            <Grid Grid.Column="1" ColumnDefinitions="{OnIdiom Phone='32, 26, 32', Desktop='40, 30, 40'}" VerticalOptions="Center">
                                                <Border Grid.Column="0" BackgroundColor="#FEE2E2" StrokeShape="RoundRectangle 10" StrokeThickness="0" WidthRequest="{OnIdiom Phone='32', Desktop='36'}" HeightRequest="{OnIdiom Phone='32', Desktop='36'}" VerticalOptions="Center">
                                                    <Button Text="−" Clicked="SilTiklandi" CommandParameter="{Binding .}" BackgroundColor="Transparent" TextColor="#DC2626" FontSize="{OnIdiom Phone='20', Desktop='24'}" FontAttributes="Bold" Padding="0" Margin="0" VerticalOptions="Center" HorizontalOptions="Center"/>
                                                </Border>
                                                <Label Grid.Column="1" Text="{Binding Miktar}" VerticalOptions="Center" HorizontalTextAlignment="Center" FontAttributes="Bold" FontSize="{OnIdiom Phone='14', Desktop='16'}" TextColor="#0F172A"/>
                                                <Border Grid.Column="2" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 10" StrokeThickness="0" WidthRequest="{OnIdiom Phone='32', Desktop='36'}" HeightRequest="{OnIdiom Phone='32', Desktop='36'}" VerticalOptions="Center">
                                                    <Button Text="+" Clicked="MiktarArtir_Clicked" CommandParameter="{Binding .}" BackgroundColor="Transparent" TextColor="#16A34A" FontSize="{OnIdiom Phone='20', Desktop='24'}" FontAttributes="Bold" Padding="0" Margin="0" VerticalOptions="Center" HorizontalOptions="Center"/>
                                                </Border>
                                            </Grid>

                                            <Label Grid.Column="2" Text="{Binding ToplamFiyat, StringFormat='{0:N2}₺'}" TextColor="#E67E22" FontAttributes="Bold" FontSize="{OnIdiom Phone='14', Desktop='16'}" VerticalOptions="Center" WidthRequest="{OnIdiom Phone='55', Desktop='65'}" HorizontalTextAlignment="End"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Grid ColumnDefinitions="20, Auto, *" ColumnSpacing="8" Margin="0,10,0,8" VerticalOptions="Center">
                            <BoxView Grid.Column="0" Color="#E2E8F0" HeightRequest="1" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="Onaylananlar" FontSize="11" FontAttributes="Bold" TextColor="#94A3B8" CharacterSpacing="1"/>
                            <BoxView Grid.Column="2" Color="#E2E8F0" HeightRequest="1" VerticalOptions="Center"/>
                        </Grid>

                        <CollectionView ItemsSource="{Binding SecilenMasa.Siparisler}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Urun">
                                    <Grid ColumnDefinitions="Auto, *, Auto" Padding="4,6" ColumnSpacing="10">
                                        <Border BackgroundColor="#F0FDF4" StrokeShape="RoundRectangle 6" StrokeThickness="0" Padding="6,2">
                                            <Label Text="{Binding Miktar, StringFormat='{0}×'}" TextColor="#16A34A" FontAttributes="Bold" FontSize="12"/>
                                        </Border>
                                        <Label Grid.Column="1" Text="{Binding Ad}" TextColor="#64748B" FontSize="13" VerticalOptions="Center"/>
                                        <Label Grid.Column="2" Text="{Binding ToplamFiyat, StringFormat='{0:N2}₺'}" TextColor="#94A3B8" FontSize="12" VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </ScrollView>

                <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,12,0,0">
                    <Border BackgroundColor="#F8FAFC" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="{OnIdiom Phone='12,10', Desktop='14,12'}">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="TOPLAM" FontSize="11" FontAttributes="Bold" TextColor="#94A3B8" CharacterSpacing="2" VerticalOptions="Center"/>
                            <Label Grid.Column="1" x:Name="ToplamLabel" Text="0,00 ₺" FontSize="{OnIdiom Phone='20', Desktop='24'}" FontAttributes="Bold" TextColor="#0F172A"/>
                        </Grid>
                    </Border>

                    <Border x:Name="AnaButonBorder" StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="#E67E22">
                        <Border.Shadow>
                            <Shadow Brush="#E67E22" Offset="0,4" Radius="14" Opacity="0.35"/>
                        </Border.Shadow>
                        <Button x:Name="AnaButon" HeightRequest="{OnIdiom Phone='48', Desktop='54'}" FontAttributes="Bold" FontSize="15" CharacterSpacing="1" TextColor="White" BackgroundColor="Transparent" Clicked="AnaButon_Clicked"/>
                    </Border>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                        <Border Grid.Column="0" BackgroundColor="#FFFBEB" StrokeShape="RoundRectangle 12" Stroke="#FDE68A" StrokeThickness="1">
                            <Button Text="↗  Aktar" Clicked="MasaAktar_Clicked" BackgroundColor="Transparent" TextColor="#B45309" FontAttributes="Bold" FontSize="13" HeightRequest="{OnIdiom Phone='40', Desktop='44'}"/>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#F5F3FF" StrokeShape="RoundRectangle 12" Stroke="#DDD6FE" StrokeThickness="1">
                            <Button Text="🔗  Birleştir" Clicked="MasaBirlestir_Clicked" BackgroundColor="Transparent" TextColor="#6D28D9" FontAttributes="Bold" FontSize="13" HeightRequest="{OnIdiom Phone='40', Desktop='44'}"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Grid>
        </Border>

    </Grid>
</ContentPage>