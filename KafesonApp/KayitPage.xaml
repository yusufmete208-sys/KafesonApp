<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.KayitPage"
             Title="Kayıt Ol"
             BackgroundColor="#ECF0F1">

    <VerticalStackLayout VerticalOptions="Center" Padding="30" Spacing="20">
        <Label Text="KAFESON" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>
        <Label Text="Yönetici Kaydı" FontSize="16" HorizontalOptions="Center" TextColor="Gray"/>

        <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0">
            <Entry x:Name="KullaniciAdiEntry" Placeholder="Kullanıcı Adı" TextColor="#2C3E50" HeightRequest="50"/>
        </Border>

        <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="0">
            <Entry x:Name="SifreEntry" Placeholder="Şifre" IsPassword="True" TextColor="#2C3E50" HeightRequest="50"/>
        </Border>

        <Button Text="KAYIT OL" Clicked="KayitOl_Clicked" 
                BackgroundColor="#2980B9" TextColor="White" FontAttributes="Bold" 
                CornerRadius="10" HeightRequest="50"/>
    </VerticalStackLayout>
</ContentPage>  