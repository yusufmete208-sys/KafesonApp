<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.KayitPage"
             Title="Yeni Personel Kaydı"
             BackgroundColor="#F4F7F6">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="YENİ HESAP OLUŞTUR" FontSize="24" FontAttributes="Bold" TextColor="#2C3E50" HorizontalOptions="Center"/>

            <Entry x:Name="KadiEntry" Placeholder="Kullanıcı Adı" BackgroundColor="White"/>
            <Entry x:Name="SifreEntry" Placeholder="Şifre" IsPassword="True" BackgroundColor="White"/>

            <Label Text="Yetkiler (Erişebileceği Sayfalar)" FontAttributes="Bold" Margin="0,10,0,0"/>

            <HorizontalStackLayout Spacing="10">
                <CheckBox x:Name="CheckMasalar" Color="#27AE60"/>
                <Label Text="Masalar / Sipariş Ekranı" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox x:Name="CheckRaporlar" Color="#27AE60"/>
                <Label Text="Raporları Görüntüle" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="10">
                <CheckBox x:Name="CheckAyarlar" Color="#27AE60"/>
                <Label Text="Ayarlar / Yönetim Paneli" VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Button Text="KAYDET" Clicked="Kaydet_Clicked" BackgroundColor="#27AE60" TextColor="White" HeightRequest="50" CornerRadius="10" Margin="0,20,0,0"/>

            <Button Text="Vazgeç" Clicked="Vazgec_Clicked" BackgroundColor="Transparent" TextColor="#7F8C8D"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>