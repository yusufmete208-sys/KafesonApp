<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:KafesonApp.Models"
             x:Class="KafesonApp.SistemLogsPage"
             Title="Sistem İşlem Kayıtları"
             BackgroundColor="#F0F4F8"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" BackgroundColor="#1E293B" StrokeThickness="0" Padding="15,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto, *">
                <Button Text="← Geri Dön" Clicked="GeriDon_Clicked" BackgroundColor="#E74C3C" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="40" Padding="15,0"/>
                <Label Grid.Column="1" Text="SİSTEM LOGLARI" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" Margin="-60,0,0,0"/>
            </Grid>
        </Border>

        <CollectionView Grid.Row="1" x:Name="LogListesi" Margin="15,20,15,0">
            <CollectionView.EmptyView>
                <Label Text="Henüz bir sistem kaydı bulunmuyor." TextColor="Gray" HorizontalOptions="Center" VerticalOptions="Center"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SistemLog">
                    <Border Margin="0,0,0,10" BackgroundColor="White" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" WidthRequest="60">
                                <Label Text="{Binding Tarih, StringFormat='{0:dd MMM}'}" FontSize="11" TextColor="#7F8C8D" HorizontalTextAlignment="Center"/>
                                <Label Text="{Binding Tarih, StringFormat='{0:HH:mm}'}" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" HorizontalTextAlignment="Center"/>
                            </VerticalStackLayout>

                            <BoxView Grid.Column="0" HorizontalOptions="End" WidthRequest="2" Color="#E2E8F0" Margin="0,-15"/>

                            <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="8">
                                    <Border BackgroundColor="#E8F6F3" StrokeThickness="0" StrokeShape="RoundRectangle 5" Padding="5,2">
                                        <Label Text="{Binding IslemTuru}" TextColor="#27AE60" FontSize="11" FontAttributes="Bold"/>
                                    </Border>
                                    <Label Text="{Binding PersonelAdi, StringFormat='👤 {0}'}" FontSize="12" TextColor="#3498DB" FontAttributes="Bold" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label Text="{Binding Detay}" TextColor="#2C3E50" FontSize="14"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>