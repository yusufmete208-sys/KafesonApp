<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.MasaYonetimView">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="20">

        <Frame Grid.Row="0" CornerRadius="10" BorderColor="#DCDDE1" Padding="15" BackgroundColor="White">
            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Entry x:Name="MasaNoEntry" Placeholder="Masa No (Örn: 5)" Keyboard="Numeric" WidthRequest="150"/>
                <Button Text="MASA EKLE" 
                        Clicked="OnMasaEkleClicked" 
                        BackgroundColor="#27AE60" TextColor="White" FontAttributes="Bold"/>
            </HorizontalStackLayout>
        </Frame>

        <CollectionView Grid.Row="1" x:Name="MasaCollectionView">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="3" VerticalItemSpacing="10" HorizontalItemSpacing="10"/>
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame HeightRequest="120" CornerRadius="12" BorderColor="#DCDDE1" HasShadow="False">
                        <Frame.Triggers>
                            <DataTrigger TargetType="Frame" Binding="{Binding IsDolu}" Value="True">
                                <Setter Property="BackgroundColor" Value="#FAB1A0"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Frame" Binding="{Binding IsDolu}" Value="False">
                                <Setter Property="BackgroundColor" Value="#F1F2F6"/>
                            </DataTrigger>
                        </Frame.Triggers>

                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="{Binding No, StringFormat='Masa {0}'}" FontAttributes="Bold" TextColor="#2F3640"/>
                            <Label Text="{Binding KalanTutar, StringFormat='{0:N2} TL'}" FontSize="12" TextColor="Gray"/>

                            <Button Text="SİL" 
                                    Clicked="OnMasaSilClicked" 
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#E74C3C" TextColor="White" Scale="0.8" Margin="0,5,0,0"/>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentView>