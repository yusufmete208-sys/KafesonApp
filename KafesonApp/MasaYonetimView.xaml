<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.MasaYonetimiView">

    <VerticalStackLayout Padding="10" Spacing="15">

        <Frame BorderColor="#D5D8DC" Padding="15" CornerRadius="12">
            <VerticalStackLayout Spacing="10">
                <Label Text="YENİ MASA EKLE" FontAttributes="Bold" TextColor="#2C3E50"/>

                <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="10">
                    <Entry x:Name="MasaNoEntry" Placeholder="No" Keyboard="Numeric" Grid.Column="0"/>

                    <Picker x:Name="MekanPicker" Title="Mekan" Grid.Column="1">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>İç Mekan</x:String>
                                <x:String>Bahçe</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>

                    <Button Text="EKLE" Clicked="MasaEkle_Clicked" BackgroundColor="#27AE60" TextColor="White" Grid.Column="2"/>
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
            <Button x:Name="BtnFiltreIcMekan" Text="İÇ MEKAN" Clicked="Filtrele_Clicked" CommandParameter="İç Mekan" BackgroundColor="#3498DB" TextColor="White"/>
            <Button x:Name="BtnFiltreBahce" Text="BAHÇE" Clicked="Filtrele_Clicked" CommandParameter="Bahçe" BackgroundColor="#ECF0F1" TextColor="#2C3E50" Grid.Column="1"/>
        </Grid>

        <CollectionView x:Name="MasaListesi" HeightRequest="300">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*, Auto" Padding="10">
                        <Label Text="{Binding No, StringFormat='Masa {0}'}" VerticalOptions="Center" FontSize="16"/>
                        <Button Grid.Column="1" Text="SİL" Clicked="MasaSil_Clicked" CommandParameter="{Binding .}" BackgroundColor="#E74C3C" TextColor="White" HeightRequest="35"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentView>