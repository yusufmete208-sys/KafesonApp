<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KafesonApp.MasaYonetimiPage"
             Title="Masa Yönetimi">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" HorizontalOptions="Center" WidthRequest="450">

            <Label Text="MASA YÖNETİMİ" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#2C3E50"/>

            <Border Stroke="#DDE1E3" StrokeThickness="1" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Yeni Masa Numarası" FontAttributes="Bold"/>
                    <Entry x:Name="MasaNoEntry" Placeholder="Örn: 15" Keyboard="Numeric" HeightRequest="45"/>
                    <Button Text="MASAYI SİSTEME EKLE" Clicked="MasaEkle_Clicked" BackgroundColor="#27AE60" CornerRadius="8"/>
                </VerticalStackLayout>
            </Border>

            <Label Text="Mevcut Masalar" FontAttributes="Bold" Margin="0,10,0,0"/>

            <CollectionView x:Name="MasaListesi">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,5" Padding="12" Stroke="#EEEEEE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>

                            <Grid ColumnDefinitions="*, Auto">
                                <Label Text="{Binding No, StringFormat='Masa {0}'}" VerticalOptions="Center" FontAttributes="Bold" TextColor="#34495E"/>
                                <Button Grid.Column="1" Text="Sil" Clicked="MasaSil_Clicked" 
                                        CommandParameter="{Binding .}" BackgroundColor="#C0392B" 
                                        HeightRequest="35" WidthRequest="60" CornerRadius="5"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="AYARLARA GERİ DÖN" Clicked="GeriDon_Clicked" 
                    BackgroundColor="#95A5A6" HeightRequest="50" CornerRadius="10" Margin="0,20"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>